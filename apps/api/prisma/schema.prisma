generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleName {
  EMPLOYEE
  MANAGER
  SENIOR_MANAGER
  ADMIN
}

enum ClaimStatus {
  DRAFT
  PENDING_MANAGER
  PENDING_SENIOR_MANAGER
  REVERTED_TO_MANAGER
  REVERTED_TO_EMPLOYEE
  APPROVED
  REJECTED
}

enum WorkflowStep {
  EMPLOYEE
  MANAGER
  SENIOR_MANAGER
  COMPLETED
}

enum ClaimAction {
  CREATE_DRAFT
  SUBMIT
  MANAGER_APPROVE
  MANAGER_REJECT
  SENIOR_MANAGER_APPROVE
  SENIOR_MANAGER_REJECT
  SENIOR_MANAGER_REVERT
  MANAGER_REAPPROVE
  MANAGER_REVERT_TO_EMPLOYEE
  EMPLOYEE_EDIT
  EMPLOYEE_RESUBMIT
  DELETE_DRAFT
}

enum ClaimCategory {
  TRAVEL
  MEALS
  ACCOMMODATION
  OFFICE_SUPPLIES
  SOFTWARE
  TRANSPORT
  OTHER
}

model Role {
  id        String   @id @default(uuid())
  name      RoleName @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     User[]

  @@map("roles")
}

model User {
  id                    String           @id @default(uuid())
  name                  String
  email                 String           @unique
  passwordHash          String
  roleId                String
  managerId             String?
  seniorManagerId       String?
  isActive              Boolean          @default(true)
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  role                  Role             @relation(fields: [roleId], references: [id])
  manager               User?            @relation("EmployeeManager", fields: [managerId], references: [id])
  employees             User[]           @relation("EmployeeManager")
  seniorManager         User?            @relation("ManagerSeniorManager", fields: [seniorManagerId], references: [id])
  managers              User[]           @relation("ManagerSeniorManager")
  employeeClaims        Claim[]          @relation("EmployeeClaims")
  pendingClaims         Claim[]          @relation("PendingClaims")
  assignedManagerClaims Claim[]          @relation("AssignedManagerClaims")
  assignedSeniorClaims  Claim[]          @relation("AssignedSeniorClaims")
  approvalHistory       ApprovalHistory[]
  refreshSessions       RefreshSession[]

  @@index([managerId])
  @@index([seniorManagerId])
  @@map("users")
}

model Claim {
  id                      String            @id @default(uuid())
  claimNumber             String            @unique
  employeeId              String
  amount                  Decimal           @db.Decimal(12, 2)
  currency                String            @default("INR")
  category                ClaimCategory
  description             String
  expenseDate             DateTime
  receiptUrl              String?
  status                  ClaimStatus       @default(DRAFT)
  currentStep             WorkflowStep      @default(EMPLOYEE)
  pendingWithUserId       String?
  assignedManagerId       String
  assignedSeniorManagerId String
  submittedAt             DateTime?
  resolvedAt              DateTime?
  version                 Int               @default(0)
  deletedAt               DateTime?
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt
  employee                User              @relation("EmployeeClaims", fields: [employeeId], references: [id])
  pendingWith             User?             @relation("PendingClaims", fields: [pendingWithUserId], references: [id])
  assignedManager         User              @relation("AssignedManagerClaims", fields: [assignedManagerId], references: [id])
  assignedSeniorManager   User              @relation("AssignedSeniorClaims", fields: [assignedSeniorManagerId], references: [id])
  history                 ApprovalHistory[]

  @@index([employeeId])
  @@index([pendingWithUserId])
  @@index([status])
  @@index([pendingWithUserId, status, createdAt])
  @@index([employeeId, createdAt])
  @@index([expenseDate])
  @@map("claims")
}

model ApprovalHistory {
  id         String        @id @default(uuid())
  claimId    String
  actorId    String
  action     ClaimAction
  fromStatus ClaimStatus?
  toStatus   ClaimStatus
  step       WorkflowStep
  note       String?
  metadata   Json?
  createdAt  DateTime      @default(now())
  claim      Claim         @relation(fields: [claimId], references: [id])
  actor      User          @relation(fields: [actorId], references: [id])

  @@index([claimId])
  @@index([actorId, createdAt])
  @@map("approval_history")
}

model RefreshSession {
  id                  String    @id @default(uuid())
  userId              String
  tokenHash           String
  expiresAt           DateTime
  revokedAt           DateTime?
  replacedBySessionId String?
  userAgent           String?
  ipAddress           String?
  createdAt           DateTime  @default(now())
  user                User      @relation(fields: [userId], references: [id])
  replacedBySession   RefreshSession? @relation("RefreshReplacement", fields: [replacedBySessionId], references: [id])
  replacedSessions    RefreshSession[] @relation("RefreshReplacement")

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_sessions")
}
